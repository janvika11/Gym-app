# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gymapp

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin default (change after first login)
ADMIN_EMAIL=admin@gym.com
ADMIN_PASSWORD=admin123

# Meta WhatsApp Cloud API (create app at developers.facebook.com)
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=
# For subscribe link (wa.me) – your business number, e.g. 919876543210
META_WHATSAPP_PHONE_NUMBER=
# PRODUCTION: Create template in Meta WhatsApp Manager:
#   Name: gym_welcome | Body: Message: {{1}}. (or Hi! {{1}} 😊) | Submit for approval
# Then set (members get welcome without sending "Hi"):
# META_WHATSAPP_WELCOME_TEMPLATE_NAME=gym_welcome
# META_WHATSAPP_DYNAMIC_TEMPLATE_NAME=gym_welcome
# META_WHATSAPP_WELCOME_TEMPLATE_LANG=en
